{
  "name": "oqto-website",
  "version": "1.0.0",
  "description": "Oqto documentation website - Self-hosted AI agent platform",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/server.ts",
    "build": "bun run scripts/build.ts",
    "preview": "bun run scripts/preview.ts",
    "lint": "biome check .",
    "lint:fix": "biome check . --write",
    "format": "biome format . --write",
    "typecheck": "tsc --noEmit",
    "serve": "bun run src/server.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bun": "latest",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "beautiful-mermaid": "^0.1.3"
  }
}
